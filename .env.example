## Public envs (safe for browser)
NEXT_PUBLIC_APP_NAME="HRMS Web"
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"

## Supabase (same project as legacy HRMS app — used by `/api/*` route handlers)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

## Signed session cookie for `/api/auth/login` (generate a long random string in production)
AUTH_SECRET="change-me-in-production"

## API / Auth base URLs (placeholders — wire your backend later)
NEXT_PUBLIC_API_BASE_URL="https://api.example.com"
NEXT_PUBLIC_AUTH_BASE_URL="https://auth.example.com"

## OAuth placeholders (if enabled in `src/config/authConfig.ts`)
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
NEXT_PUBLIC_GOOGLE_REDIRECT_URI="http://localhost:3000/auth/oauth/callback"

